# paper-scholar .gitignore

# ============================================================
#  User data directory — everything under .paper-scholar/
#  is generated at runtime and varies per user. NEVER commit.
# ============================================================
.paper-scholar/

# User-specific skill state (generated at runtime)
.skill_state.json

# Extracted text files (can be regenerated from PDFs)
*.txt

# Python cache
__pycache__/
*.pyc

# OS files
.DS_Store
Thumbs.db
